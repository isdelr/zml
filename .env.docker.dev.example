# Public URLs
NEXT_PUBLIC_CONVEX_URL=http://localhost:3210
CONVEX_SELF_HOSTED_URL=http://localhost:3210
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_APP_RELEASE=0.1.0-dev

# Convex self-hosted control plane
INSTANCE_NAME=zml-dev
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-generated-admin-key
INSTANCE_SECRET=replace-with-64-char-hex-string
CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
CONVEX_SITE_ORIGIN=http://localhost:3211
CONVEX_SITE_URL=http://localhost:3211
DATABASE_UDF_USER_TIMEOUT_SECONDS=5

# Postgres (Convex persistence)
# Keep CONVEX_POSTGRES_DB aligned with INSTANCE_NAME, replacing "-" with "_".
POSTGRES_USER=convex
POSTGRES_PASSWORD=convex_dev_password_change_me
CONVEX_POSTGRES_DB=zml_dev

# Auth redirect (frontend URL for OAuth callbacks)
SITE_URL=http://localhost:3000
NEXT_PUBLIC_MEDIA_DELIVERY_BASE_URL=
MEDIA_DELIVERY_BASE_URL=
MEDIA_ORIGIN_BASE_URL=http://localhost:3000
MEDIA_ACCESS_SECRET=replace-with-64-char-hex-string
MEDIA_ACCESS_TTL_SECONDS=3600

# Discord auth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_SERVER_ID=

# Shared bot integration secrets
ZML_DISCORD_API_TOKEN=
ZML_DISCORD_WEBHOOK_URL=
ZML_DISCORD_WEBHOOK_SECRET=

# Auth signing keys
# Generate with: node generateKeys.mjs
# Output is a Better Auth doc-array with both public and private keys.
JWKS=

# Backblaze B2 (S3-compatible)
B2_BUCKET=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_KEY_ID=
B2_APPLICATION_KEY=

# Optional Cloudflare cache purge support for stable media paths
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Optional authenticated media-maintenance endpoint
MEDIA_MAINTENANCE_SECRET=replace-with-64-char-hex-string

# App integrations
APP_RELEASE=0.1.0-dev
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
YOUTUBE_API_KEY=
GENIUS_ACCESS_TOKEN=
