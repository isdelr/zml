# Public URLs
NEXT_PUBLIC_CONVEX_URL=https://convex.example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Convex self-hosted control plane
INSTANCE_NAME=zml-prod
CONVEX_SELF_HOSTED_ADMIN_KEY=
INSTANCE_SECRET=replace-with-64-char-hex-string
CONVEX_CLOUD_ORIGIN=https://convex.example.com
CONVEX_SITE_ORIGIN=https://convex.example.com
CONVEX_SITE_URL=https://convex.example.com
DATABASE_UDF_USER_TIMEOUT_SECONDS=5

# Postgres (Convex persistence)
# Keep CONVEX_POSTGRES_DB aligned with INSTANCE_NAME, replacing "-" with "_".
POSTGRES_USER=convex
POSTGRES_PASSWORD=
CONVEX_POSTGRES_DB=zml_prod

# Auth redirect (frontend URL for OAuth callbacks)
SITE_URL=https://example.com
MEDIA_ACCESS_SECRET=replace-with-64-char-hex-string
MEDIA_ACCESS_TTL_SECONDS=3600

# Discord auth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_SERVER_ID=

# Shared bot integration secrets
ZML_DISCORD_API_TOKEN=
ZML_DISCORD_WEBHOOK_URL=
ZML_DISCORD_WEBHOOK_SECRET=

# Auth signing keys
JWT_PRIVATE_KEY=
# JWKS must be the Better Auth doc-array JSON used by Convex plugin static JWKS.
# Recommended source:
#   npx convex run auth:getLatestJwks | npx convex env set JWKS
JWKS=

# Backblaze B2 (S3-compatible)
B2_BUCKET=
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_KEY_ID=
B2_APPLICATION_KEY=

# Optional authenticated media-maintenance endpoint
MEDIA_MAINTENANCE_SECRET=replace-with-64-char-hex-string
SUBMISSION_PROCESSING_SECRET=replace-with-64-char-hex-string

# Optional shared-store rate limiting for Next.js API routes
RATE_LIMIT_UPSTASH_REST_URL=
RATE_LIMIT_UPSTASH_REST_TOKEN=

# App integrations
APP_RELEASE=0.1.0
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
YOUTUBE_API_KEY=
GENIUS_ACCESS_TOKEN=

# GlitchTip (self-hosted observability)
GLITCHTIP_DOMAIN=https://glitchtip.example.com
GLITCHTIP_SECRET_KEY=
GLITCHTIP_POSTGRES_USER=glitchtip
GLITCHTIP_POSTGRES_PASSWORD=
GLITCHTIP_POSTGRES_DB=glitchtip
GLITCHTIP_EMAIL_URL=
GLITCHTIP_DEFAULT_FROM_EMAIL=
GLITCHTIP_ENABLE_USER_REGISTRATION=false
GLITCHTIP_ENABLE_ORGANIZATION_CREATION=false
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90
